# URL of your running Next.js application
NEXT_APP_URL=http://localhost:3000

# Must match MCP_API_SECRET in your Next.js .env file
MCP_API_SECRET=your-secret-here

# Shared HMAC secret used by the Next.js app to sign MCP approval decisions
MCP_APPROVAL_SECRET=your-approval-secret-here

# Transport mode: "stdio" (Claude Desktop) or "http" (remote clients: Claude.ai, ChatGPT)
# MCP_TRANSPORT=stdio

# Required for HTTP mode: public base URL of this MCP server
# MCP_PUBLIC_URL=https://your-mcp-server.com

# Port for HTTP mode (defaults to 3000)
# PORT=3000

# Strongly recommended for HTTP mode: stateless bearer token HMAC (persist across deploys)
# MCP_TOKEN_SECRET=your-64-char-hex-secret

# Persistent OAuth client registry (required for production on Railway)
# Attach a Railway volume at /data and set:
# MCP_CLIENTS_FILE=/data/mcp-clients.json
# Without this, OAuth clients are lost on every redeploy → "Unknown OAuth client" errors.

# Optional: bearer token lifetime in seconds (default 90 days)
# MCP_TOKEN_TTL_SECONDS=7776000

# Optional: per-tool timeout in milliseconds
# MCP_TOOL_TIMEOUT_MS=30000

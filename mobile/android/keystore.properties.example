# Copy to keystore.properties (gitignored). Do NOT use quotes around values.
# storeFile: relative to android/ OR absolute with FORWARD slashes only:
#   storeFile=../@rushabh2310__aagam-holidays.jks
#   storeFile=D:/path/to/upload-key.jks
# NEVER use backslashes in .properties — \n in \next13… is read as a newline.

storeFile=../your-upload-key.jks
storePassword=your-store-password
keyAlias=your-key-alias
keyPassword=your-key-password

{
  "expo": {
    "name": "Aagam Holidays",
    "slug": "aagam-holidays",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "aagamholidays",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e8612d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aagamholidays.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to share it in trip chat.",
        "NSCameraUsageDescription": "We need camera access to share photos in trip chat.",
        "NSPhotoLibraryUsageDescription": "We need photo library access to share photos in trip chat."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.aagamholidays.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#e8612d"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Aagam Holidays to access your location to share in trip chat."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Aagam Holidays to access your photos to share in trip chat.",
          "cameraPermission": "Allow Aagam Holidays to access your camera to take photos for trip chat."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f6e23049-3b76-47ee-8194-9c9ad6de731a"
      }
    },
    "owner": "rushabh2310",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f6e23049-3b76-47ee-8194-9c9ad6de731a"
    }
  }
}

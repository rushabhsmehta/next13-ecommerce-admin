{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "extends": "development-public"
    },
    "development-public": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "development",
      "env": {
        "APP_VARIANT": "public"
      },
      "android": {
        "gradleCommand": ":app:assemblePublicAppDebug"
      }
    },
    "development-staff": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "staff-development",
      "env": {
        "APP_VARIANT": "staff"
      },
      "android": {
        "gradleCommand": ":app:assembleStaffDebug"
      }
    },
    "development-finance": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "finance-development",
      "env": {
        "APP_VARIANT": "finance"
      },
      "android": {
        "gradleCommand": ":app:assembleFinanceDebug"
      }
    },
    "preview": {
      "extends": "preview-public"
    },
    "preview-public": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assemblePublicAppRelease"
      },
      "channel": "preview",
      "env": {
        "APP_VARIANT": "public",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_bWFueS1mbGFtaW5nby02LmNsZXJrLmFjY291bnRzLmRldiQ"
      }
    },
    "preview-staff": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleStaffRelease"
      },
      "channel": "staff-preview",
      "env": {
        "APP_VARIANT": "staff",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_bWFueS1mbGFtaW5nby02LmNsZXJrLmFjY291bnRzLmRldiQ"
      }
    },
    "preview-finance": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleFinanceRelease"
      },
      "channel": "finance-preview",
      "env": {
        "APP_VARIANT": "finance",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_bWFueS1mbGFtaW5nby02LmNsZXJrLmFjY291bnRzLmRldiQ"
      }
    },
    "production": {
      "extends": "production-public"
    },
    "production-public": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "gradleCommand": ":app:bundlePublicAppRelease"
      },
      "channel": "production",
      "env": {
        "APP_VARIANT": "public",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_bWFueS1mbGFtaW5nby02LmNsZXJrLmFjY291bnRzLmRldiQ"
      }
    },
    "production-staff": {
      "autoIncrement": true,
      "environment": "production",
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "gradleCommand": ":app:bundleStaffRelease"
      },
      "channel": "staff-production",
      "env": {
        "APP_VARIANT": "staff",
        "EXPO_STAFF_EAS_PROJECT_ID": "69483194-f389-44dd-91bf-38be100d9267",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com"
      }
    },
    "production-finance": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "gradleCommand": ":app:bundleFinanceRelease"
      },
      "channel": "finance-production",
      "env": {
        "APP_VARIANT": "finance",
        "EXPO_PUBLIC_API_BASE_URL": "https://admin.aagamholidays.com",
        "EXPO_PUBLIC_WEBSITE_URL": "https://aagamholidays.com",
        "EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY": "pk_test_bWFueS1mbGFtaW5nby02LmNsZXJrLmFjY291bnRzLmRldiQ"
      }
    }
  },
  "submit": {
    "production": {
      "extends": "production-public"
    },
    "production-public": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "your-app-store-connect-app-id",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account-key.json",
        "track": "internal"
      }
    },
    "production-staff": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "your-staff-app-store-connect-app-id",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account-key.json",
        "track": "internal"
      }
    },
    "production-finance": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "your-finance-app-store-connect-app-id",
        "appleTeamId": "YOUR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account-key.json",
        "track": "internal"
      }
    }
  }
}

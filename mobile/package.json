{
  "name": "aagam-holidays-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "update:production": "EXPO_PUBLIC_API_BASE_URL=https://admin.aagamholidays.com EXPO_PUBLIC_WEBSITE_URL=https://aagamholidays.com EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_bW92aW5nLXNjdWxwaW4tNzguY2xlcmsuYWNjb3VudHMuZGV2JA eas update --channel production --environment production",
    "update:preview": "EXPO_PUBLIC_API_BASE_URL=https://admin.aagamholidays.com EXPO_PUBLIC_WEBSITE_URL=https://aagamholidays.com EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_bW92aW5nLXNjdWxwaW4tNzguY2xlcmsuYWNjb3VudHMuZGV2JA eas update --channel preview --environment preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:build": "detox build --configuration android.emu.debug",
    "e2e:test": "detox test --configuration android.emu.debug",
    "e2e:build-release": "detox build --configuration android.emu.release",
    "e2e:test-release": "detox test --configuration android.emu.release"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/datetimepicker": "^8.0.0",
    "@react-navigation/native": "^7.0.0",
    "date-fns": "^3.6.0",
    "expo": "^55.0.19",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.32",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-image-picker": "~55.0.19",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "detox": "^20.18.0",
    "jest": "^29.7.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|expo-router|expo-.*|@react-navigation|react-native-.*)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "collectCoverageFrom": [
      "lib/**/*.ts",
      "hooks/**/*.ts",
      "components/**/*.tsx",
      "!/**/*.d.ts"
    ]
  }
}
